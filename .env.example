# Groq API Key (required)
GROQ_API_KEY=your_groq_api_key_here

# API authentication key (leave empty to disable in development)
API_KEY=

# Storage
UPLOAD_DIR=uploads
DATABASE_PATH=data/diet_plan.db
SESSION_TTL_HOURS=72

# Primary models
OCR_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
EXTRACTION_MODEL=moonshotai/kimi-k2-instruct

# Fallback models
OCR_VISION_MODEL_FALLBACK=meta-llama/llama-4-maverick-17b-128e-instruct
EXTRACTION_MODEL_FALLBACK=meta-llama/llama-4-scout-17b-16e-instruct

# Performance
MAX_OCR_WORKERS=8
IMAGE_ENCODE_FORMAT=JPEG
IMAGE_ENCODE_QUALITY=95
MAX_EXTRACTION_RETRIES=3
MAX_OCR_RETRIES=2
INTER_DOCUMENT_DELAY_SECONDS=2.0
RATE_LIMIT_RETRY_DELAY_SECONDS=15.0
MAX_DOCUMENTS_PER_SESSION=10

# Aggregation thresholds
CONFLICT_THRESHOLD_PERCENT=0.05
CHRONIC_CONDITION_MIN_REPORTS=2
CHRONIC_CONDITION_MIN_DAYS=30

# Diet generation
DIET_GENERATION_MODEL=llama-3.3-70b-versatile
DIET_GENERATION_MODEL_FALLBACK=qwen/qwen3-32b
MAX_DIET_GENERATION_RETRIES=2

# PubMed API key (optional — increases rate limit from 3 to 10 req/sec)
# Get free key at: https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=
